# Public origin used for canonical URLs, Open Graph, sitemap, and robots.
# Set this in your hosting provider's environment for production.
NEXT_PUBLIC_SITE_URL=https://carolinacreampups.com

# Privacy-friendly analytics (Plausible-compatible). Leave unset to disable —
# nothing loads and no third-party requests are made until you set this.
# NEXT_PUBLIC_ANALYTICS_DOMAIN=carolinacreampups.com
# NEXT_PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.js

# Add server-side secrets here (never prefix secrets with NEXT_PUBLIC_):
# Example for wiring up the contact form to an email provider —
# CONTACT_EMAIL_API_KEY=
