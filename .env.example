# Public origin used for canonical URLs, Open Graph, sitemap, and robots.
# This is environment-specific — set it per environment in your host:
#   Production: https://carolinacreampups.com
#   Staging:    https://beta.carolinacreampups.com
NEXT_PUBLIC_SITE_URL=https://carolinacreampups.com

# Set to 1 in non-production environments (e.g. the beta/staging deploy) to mark
# the whole site noindex/nofollow so it never competes with production in search.
# Leave unset (or 0) in production.
# NEXT_PUBLIC_NOINDEX=1

# Image CDN origin for real photos (Cloudflare R2 public bucket / custom domain).
# When set, manifest entries using photo() load from here and the host is added
# to next/image remotePatterns automatically. Unset = local /public/images.
# NEXT_PUBLIC_IMAGE_BASE_URL=https://images.carolinacreampups.com

# Analytics: Vercel Web Analytics (@vercel/analytics) — no env var needed;
# enable it in the Vercel project dashboard (Analytics tab).

# Editable litter + waitlist data via Airtable (see docs/ADMIN-AIRTABLE.md).
# Set both to read live; unset = in-code defaults. Server-only (never NEXT_PUBLIC_).
# AIRTABLE_API_KEY=pat_...your-personal-access-token
# AIRTABLE_BASE_ID=app...your-base-id
# Optional: lets an Airtable automation refresh the site instantly.
# REVALIDATE_SECRET=some-long-random-string

# Contact form email delivery via Resend (see docs/CONTACT-EMAIL.md).
# Set both to deliver submissions by email; unset = the route logs the inquiry.
# Server-only — never prefix secrets with NEXT_PUBLIC_.
# RESEND_API_KEY=re_...your-resend-api-key
# CONTACT_FROM_EMAIL=Carolina Cream Pups <hello@carolinacreampups.com>
# Optional: where inquiries are delivered (defaults to site.contact.email).
# CONTACT_TO_EMAIL=you@example.com
